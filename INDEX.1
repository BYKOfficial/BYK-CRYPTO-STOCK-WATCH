// ================== BACKEND ==================
const express = require("express");
const axios = require("axios");
const cors = require("cors");

const app = express();
app.use(cors());
app.use(express.json());

// 🔥 CRYPTO DATA API
app.get("/api/crypto", async (req, res) => {
  const data = await axios.get(
    "https://api.coingecko.com/api/v3/coins/markets?vs_currency=usd"
  );
  res.json(data.data);
});

// 🤖 AI SIGNAL
app.get("/api/ai/:price", (req, res) => {
  const price = Number(req.params.price);

  let signal = "HOLD";
  if (price < 25000) signal = "BUY";
  else if (price > 60000) signal = "SELL";

  res.json({ signal });
});

// 🚀 NEXT BITCOIN FINDER
app.get("/api/next-btc", async (req, res) => {
  const data = await axios.get(
    "https://api.coingecko.com/api/v3/coins/markets?vs_currency=usd"
  );

  const result = data.data
    .filter(c => c.market_cap < 5000000000 && c.price_change_percentage_24h > 5)
    .slice(0, 5);

  res.json(result);
});

// SERVER START
app.listen(5000, () => console.log("Backend running on 5000"));


// ================== FRONTEND (REACT STYLE) ==================

// Paste this in React App (App.js)

import React, { useEffect, useState } from "react";

export default function App() {
  const [crypto, setCrypto] = useState([]);
  const [search, setSearch] = useState("");
  const [nextBTC, setNextBTC] = useState([]);

  useEffect(() => {
    fetch("http://localhost:5000/api/crypto")
      .then(res => res.json())
      .then(data => setCrypto(data));

    fetch("http://localhost:5000/api/next-btc")
      .then(res => res.json())
      .then(data => setNextBTC(data));
  }, []);

  return (
    <div style={{ background: "black", color: "white", padding: "20px" }}>
      <h1>🚀 BYK Crypto AI Platform</h1>

      {/* SEARCH */}
      <input
        placeholder="Search..."
        onChange={e => setSearch(e.target.value)}
      />

      {/* CRYPTO */}
      {crypto
        .filter(c => c.name.toLowerCase().includes(search.toLowerCase()))
        .slice(0, 10)
        .map(c => (
          <div key={c.id} style={{ border: "1px solid gray", margin: "10px" }}>
            <h3>{c.name}</h3>
            <p>Price: ${c.current_price}</p>

            <AI price={c.current_price} />

            {/* CHART */}
            <iframe
              src={`https://s.tradingview.com/widgetembed/?symbol=${c.symbol.toUpperCase()}USD`}
              width="100%"
              height="200"
            />
          </div>
        ))}

      {/* NEXT BTC */}
      <h2>🔥 Next Bitcoin Coins</h2>
      {nextBTC.map((c, i) => (
        <div key={i}>
          <p>{c.name} - ${c.current_price}</p>
        </div>
      ))}
    </div>
  );
}

// AI COMPONENT
function AI({ price }) {
  const [signal, setSignal] = useState("");

  useEffect(() => {
    fetch(`http://localhost:5000/api/ai/${price}`)
      .then(res => res.json())
      .then(data => setSignal(data.signal));
  }, [price]);

  return <p>AI: {signal}</p>;
}
